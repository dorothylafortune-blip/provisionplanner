# ============================================================
# Provision Planner — Environment Variables
# ============================================================
# Copy this file to .env and fill in your Supabase credentials.
# Find these in your Supabase project → Settings → API
#
# NEVER commit your actual .env file to version control.
# ============================================================

# Your Supabase project URL (e.g. https://xyzxyz.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here
